<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Irya Projects</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f7f8fc;
      color: #111;
      text-align: center;
      padding: 60px 20px;
    }

    h1 {
      font-size: 42px;
      margin-bottom: 10px;
    }

    p {
      font-size: 20px;
      color: #555;
      margin-bottom: 40px;
    }

    .games {
      display: flex;
      justify-content: center;
      gap: 30px;
      flex-wrap: wrap;
    }

    .card {
      background: white;
      width: 280px;
      padding: 30px;
      border-radius: 18px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    .card h2 {
      margin-bottom: 15px;
    }

    .btn {
      display: inline-block;
      margin-top: 20px;
      padding: 14px 24px;
      background: #2563eb;
      color: white;
      text-decoration: none;
      border-radius: 10px;
      font-size: 18px;
      font-weight: bold;
    }

    .btn:hover {
      background: #1d4ed8;
    }
  </style>
</head>
<body>
  <h1>Irya's Game Studio 🎮</h1>
  <p>Games built and designed by Irya</p>

  <div class="games">
    <div class="card">
      <h2>Escape Room</h2>
      <p>Solve puzzles and escape before time runs out.</p>
      <a class="btn" href="./escape-room/">Play Now</a>
    </div>

    <div class="card">
      <h2>Lets Cook</h2>
      <p>Cook, play, and complete fun kitchen challenges.</p>
      <a class="btn" href="./lets-cook/">Play Now</a>
    </div>
  </div>
</body>
</html>